#version 450

layout(push_constant) uniform upc {
  uint jump;
  uint div;
} pc;

struct inst {
  vec4 rot;
  vec4 pos;  // pos.xyz + mdl
  vec4 size; // size.xyz + txt
};

layout(binding = 0, set = 0) buffer buf_0 { inst inp[]; };

int cmp(vec4 a, vec4 b) {
  // "empty" spaces at the end  
  if (a.w == 0) return 1;
  if (b.w == 0) return -1;
  // w first to cover "mdl" first
  if (a.w < b.w) return -1;
  if (a.w > b.w) return 1;
  // then by z, because it's always nice to have things z-sorted
  if (a.z < b.z) return -1;
  if (a.z > b.z) return 1;

  if (a.y < b.y) return -1;
  if (a.y > b.y) return 1;
  if (a.x < b.x) return -1;
  if (a.x > b.x) return 1;
  return 0;
}
int cmp(inst a, inst b) {
  int flip = ((gl_GlobalInvocationID.x / pc.jump) % 2 != 0) ? -1 : 1;

  int c = cmp(a.pos, b.pos);
  if (c != 0) return c * flip;

  c = cmp(a.rot, b.rot);
  if (c != 0) return c * flip;

  return cmp(a.size, b.size) * flip;
}

uvec2 rot(uvec3 id, uint div) {
  uint ia = id.x;
  uint rb = (ia + div / 2) % div;
  uint ib = (ia / div) * div + rb;
  return uvec2(ia, ib);
}

void g2g(uvec2 i) {
  if (i.y < i.x) return;

  inst a = inp[i.x];
  inst b = inp[i.y];
  int c = cmp(a, b);
  inp[i.x] = c < 0 ? a : b;
  inp[i.y] = c > 0 ? a : b;
}

#define SZ 32
layout(local_size_x = SZ) in;
shared inst sha[SZ];
shared inst shb[SZ];

void g2a(uvec2 g) {
  inst a = inp[g.x];
  inst b = inp[g.y];
  int c = cmp(a, b) * (g.y < g.x ? -1 : 1);
  sha[gl_LocalInvocationID.x] = c < 0 ? a : b;
}
void a2b(uvec2 g) {
  inst a = sha[g.x];
  inst b = sha[g.y];
  int c = cmp(a, b) * (g.y < g.x ? -1 : 1);
  shb[gl_LocalInvocationID.x] = c < 0 ? a : b;
}
void b2a(uvec2 g) {
  inst a = shb[g.x];
  inst b = shb[g.y];
  int c = cmp(a, b) * (g.y < g.x ? -1 : 1);
  sha[gl_LocalInvocationID.x] = c < 0 ? a : b;
}
void b2g(uvec2 g) {
  inst a = shb[g.x];
  inst b = shb[g.y];
  int c = cmp(a, b) * (g.y < g.x ? -1 : 1);
  inp[gl_GlobalInvocationID.x] = c < 0 ? a : b;
}

void main() {
  if (pc.div > SZ) {
    g2g(rot(gl_GlobalInvocationID, pc.div));
    return;
  } else if (pc.div < SZ) {
    return;
  }

  g2a(rot(gl_GlobalInvocationID, 32));
  memoryBarrierShared();
  a2b(rot(gl_LocalInvocationID, 16));
  memoryBarrierShared();
  b2a(rot(gl_LocalInvocationID, 8));
  memoryBarrierShared();
  a2b(rot(gl_LocalInvocationID, 4));
  memoryBarrierShared();
  b2g(rot(gl_LocalInvocationID, 2));
}
